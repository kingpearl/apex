#!/usr/bin/env node

"use strict";

const { promises: fs, constants } = require("fs");
const path = require("path");
const setWallpaper = require("../index.js");
const argv = require("minimist")(process.argv.slice(2));

const VALID_SOURCES = new Set(["bing", "walls", "random"]);

const getUserHome = function () {
  return process.env[process.platform == "win32" ? "USERPROFILE" : "HOME"];
};

async function ensureWallpaperDirectoryExists() {
  const directory =
    argv.directory || path.join(getUserHome(), ".wallpapers");
  try {
    await fs.access(directory, constants.W_OK);
    return directory;
  } catch (err) {
    if (err.code !== "ENOENT") {
      console.error(`Cannot write in ${directory}`);
      throw err;
    }
  }

  try {
    await fs.mkdir(directory);
    return directory;
  } catch (err) {
    console.error("Could not create wallpaper directory");
    throw err;
  }
}

(async function () {
  const source = argv.source || "random";
  if (!VALID_SOURCES.has(source)) {
    console.error(
      `Invalid --source=${source}. Expected one of: bing, walls, random.`,
    );
    process.exit(1);
  }
  const directory = await ensureWallpaperDirectoryExists();
  await setWallpaper(directory, source);
  console.log("Wallpaper updated.");
})();
